import React, { useEffect, useMemo, useState } from "react";
import {
  Alert, Box, Button, Card, CardContent, Chip, CircularProgress,
  Dialog, DialogActions, DialogContent, DialogTitle, Divider,
  Grid, Stack, Tab, Tabs, Table, TableBody, TableCell,
  TableContainer, TableHead, TableRow, TextField, Typography,
} from "@mui/material";
import { API, authHeaders } from "../services/api";

export default function Sales() {
  const role = localStorage.getItem("role") || "rep";
  const [sales, setSales] = useState([]);
  const [products, setProducts] = useState([]);
  const [search, setSearch] = useState("");
  const [view, setView] = useState("all");
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState("");
  const [message, setMessage] = useState("");
  const [checkoutOpen, setCheckoutOpen] = useState(false);
  const [saving, setSaving] = useState(false);
  const [cart, setCart] = useState([]);
  const [customer, setCustomer] = useState({ name: "", email: "", phone: "" });

  useEffect(() => {
    Promise.all([loadSales(), loadProducts()]);
    const params = new URLSearchParams(window.location.search);
    const payment = params.get("merch_payment");
    const checkoutRef = params.get("checkout_ref");
    if (payment === "success") {
      setMessage("Clover payment submitted. Waiting for payment confirmation...");
      if (checkoutRef) pollCheckout(checkoutRef);
    } else if (payment === "failure") {
      setError("Clover payment was not completed.");
    }
  }, []);

  async function loadSales() {
    try {
      setLoading(true);
      const response = await fetch(`${API}/api/sales`, { headers: authHeaders() });
      const data = await response.json();
      if (!response.ok) throw new Error(data.detail || "Could not load sales.");
      setSales(Array.isArray(data) ? data : []);
    } catch (err) { setError(err.message); }
    finally { setLoading(false); }
  }

  async function loadProducts() {
    const response = await fetch(`${API}/api/products`, { headers: authHeaders() });
    const data = await response.json();
    if (response.ok) setProducts(Array.isArray(data) ? data : []);
  }

  async function pollCheckout(checkoutId) {
    for (let attempt = 0; attempt < 12; attempt += 1) {
      const response = await fetch(`${API}/api/merchandise-checkouts/${checkoutId}`, {
        headers: authHeaders(),
      });
      const data = await response.json();
      if (response.ok && data.status === "paid") {
        setMessage("Payment approved. Merchandise sale recorded.");
        await Promise.all([loadSales(), loadProducts()]);
        return;
      }
      await new Promise((resolve) => setTimeout(resolve, 2000));
    }
    setMessage("Payment is still processing. Refresh Sales in a moment.");
  }

  const merchandiseProducts = useMemo(
    () => products.filter((p) => p.active && p.category === "merchandise"),
    [products]
  );

  function addToCart(product) {
    setCart((old) => {
      const existing = old.find((item) => item.product_id === product.id);
      if (existing) {
        return old.map((item) => item.product_id === product.id
          ? { ...item, quantity: item.quantity + 1 } : item);
      }
      return [...old, { product_id: product.id, name: product.name,
        price: Number(product.price || 0), quantity: 1,
        stock: Number(product.stock_quantity || 0), track: Boolean(product.track_inventory) }];
    });
  }

  function changeQuantity(productId, change) {
    setCart((old) => old.map((item) => item.product_id === productId
      ? { ...item, quantity: Math.max(0, item.quantity + change) } : item)
      .filter((item) => item.quantity > 0));
  }

  const cartTotal = cart.reduce((sum, item) => sum + item.price * item.quantity, 0);

  async function payWithClover() {
    if (!customer.name.trim()) return setError("Customer name is required.");
    if (!cart.length) return setError("Add merchandise to the cart.");

    try {
      setSaving(true); setError("");
      const response = await fetch(`${API}/api/merchandise-checkouts`, {
        method: "POST",
        headers: { ...authHeaders(), "Content-Type": "application/json" },
        body: JSON.stringify({
          customer_name: customer.name,
          customer_email: customer.email,
          customer_phone: customer.phone,
          cart: cart.map(({ product_id, quantity }) => ({ product_id, quantity })),
        }),
      });
      const data = await response.json();
      if (!response.ok) throw new Error(data.detail || "Could not start Clover checkout.");
      localStorage.setItem("pendingMerchandiseCheckout", String(data.checkout_id));
      window.location.href = data.checkout_url;
    } catch (err) { setError(err.message); setSaving(false); }
  }

  const filteredSales = sales.filter((sale) => {
    if (view === "merchandise" && sale.category !== "merchandise") return false;
    if (view === "memberships" && sale.category === "merchandise") return false;
    const q = search.trim().toLowerCase();
    return !q || [sale.member, sale.rep, sale.product, sale.membership, sale.category]
      .some((v) => String(v || "").toLowerCase().includes(q));
  });

  return <Box>
    <Box sx={{ display: "flex", flexDirection: { xs: "column", sm: "row" },
      justifyContent: "space-between", gap: 2, mb: 3 }}>
      <Box>
        <Typography variant="h4" fontWeight="bold">{role === "rep" ? "My Sales" : "Sales"}</Typography>
        <Typography color="text.secondary">{filteredSales.length} transactions</Typography>
      </Box>
      <Button variant="contained" color="error" onClick={() => setCheckoutOpen(true)}>
        Merchandise POS
      </Button>
    </Box>

    {message && <Alert severity="success" sx={{ mb: 2 }}>{message}</Alert>}
    {error && <Alert severity="error" sx={{ mb: 2 }}>{error}</Alert>}

    <Card sx={{ borderRadius: 3, mb: 3 }}><CardContent>
      <Tabs value={view} onChange={(_, v) => setView(v)} variant="scrollable">
        <Tab value="all" label="All Sales" /><Tab value="memberships" label="Memberships" />
        <Tab value="merchandise" label="Merchandise" />
      </Tabs>
    </CardContent></Card>

    <TextField fullWidth label="Search sales" value={search}
      onChange={(e) => setSearch(e.target.value)} sx={{ mb: 3 }} />

    <Card sx={{ borderRadius: 3 }}><CardContent sx={{ p: { xs: 1, sm: 2 } }}>
      {loading ? <Box sx={{ display: "flex", justifyContent: "center", p: 5 }}>
        <CircularProgress color="error" /></Box> :
      <TableContainer><Table size="small" sx={{ minWidth: 850 }}>
        <TableHead><TableRow><TableCell>Customer</TableCell>
          {role !== "rep" && <TableCell>Rep</TableCell>}<TableCell>Product</TableCell>
          <TableCell>Type</TableCell><TableCell>Qty</TableCell><TableCell>Amount</TableCell>
          <TableCell>Status</TableCell><TableCell>Date</TableCell></TableRow></TableHead>
        <TableBody>{filteredSales.map((sale) => <TableRow key={sale.id} hover>
          <TableCell>{sale.member || "-"}</TableCell>
          {role !== "rep" && <TableCell>{sale.rep || "-"}</TableCell>}
          <TableCell>{sale.product || sale.membership || "-"}</TableCell>
          <TableCell><Chip size="small" label={sale.category === "merchandise" ? "Merchandise" : "Membership"}
            color={sale.category === "merchandise" ? "error" : "default"} /></TableCell>
          <TableCell>{sale.quantity || 1}</TableCell>
          <TableCell>${Number(sale.amount || 0).toFixed(2)}</TableCell>
          <TableCell><Chip size="small" label={sale.payment_status || "pending"}
            color={sale.payment_status === "paid" ? "success" : "warning"} /></TableCell>
          <TableCell>{sale.sale_date ? new Date(sale.sale_date).toLocaleDateString() : "-"}</TableCell>
        </TableRow>)}</TableBody>
      </Table></TableContainer>}
    </CardContent></Card>

    <Dialog open={checkoutOpen} onClose={() => !saving && setCheckoutOpen(false)} fullWidth maxWidth="lg">
      <DialogTitle fontWeight="bold">TNG Merchandise POS</DialogTitle>
      <DialogContent>
        <Grid container spacing={3} sx={{ mt: 0 }}>
          <Grid item xs={12} md={7}>
            <Typography variant="h6" fontWeight="bold" sx={{ mb: 2 }}>Products</Typography>
            <Grid container spacing={2}>{merchandiseProducts.map((product) =>
              <Grid item xs={6} sm={4} key={product.id}><Card onClick={() => addToCart(product)}
                sx={{ height: "100%", cursor: "pointer", borderRadius: 3, '&:hover': { boxShadow: 5 } }}>
                <CardContent><Typography fontWeight="bold">{product.name}</Typography>
                  <Typography variant="h6" color="error">${Number(product.price || 0).toFixed(2)}</Typography>
                  {product.track_inventory && <Typography variant="caption">Stock: {product.stock_quantity || 0}</Typography>}
                  <Button fullWidth variant="contained" color="error" sx={{ mt: 2 }}>Add</Button>
                </CardContent></Card></Grid>)}</Grid>
          </Grid>
          <Grid item xs={12} md={5}>
            <Typography variant="h6" fontWeight="bold">Cart</Typography><Divider sx={{ my: 2 }} />
            <Stack spacing={1}>{cart.map((item) => <Card key={item.product_id} sx={{ p: 2 }}>
              <Typography fontWeight="bold">{item.name}</Typography>
              <Stack direction="row" justifyContent="space-between" alignItems="center">
                <Stack direction="row" spacing={1}><Button onClick={() => changeQuantity(item.product_id, -1)}>-</Button>
                  <Typography sx={{ pt: 1 }}>{item.quantity}</Typography>
                  <Button onClick={() => changeQuantity(item.product_id, 1)}>+</Button></Stack>
                <Typography>${(item.price * item.quantity).toFixed(2)}</Typography>
              </Stack></Card>)}</Stack>
            <Divider sx={{ my: 2 }} /><Typography variant="h5" fontWeight="bold">Total: ${cartTotal.toFixed(2)}</Typography>
            <Stack spacing={2} sx={{ mt: 2 }}><TextField label="Customer Name" value={customer.name}
              onChange={(e) => setCustomer({ ...customer, name: e.target.value })} />
              <TextField label="Email (optional)" value={customer.email}
                onChange={(e) => setCustomer({ ...customer, email: e.target.value })} />
              <TextField label="Phone (optional)" value={customer.phone}
                onChange={(e) => setCustomer({ ...customer, phone: e.target.value })} />
              <Button variant="contained" color="success" size="large" onClick={payWithClover}
                disabled={saving || !cart.length}>{saving ? "Opening Clover..." : "Pay with Clover"}</Button>
            </Stack>
          </Grid>
        </Grid>
      </DialogContent>
      <DialogActions><Button onClick={() => setCheckoutOpen(false)} disabled={saving}>Close</Button></DialogActions>
    </Dialog>
  </Box>;
}
